#!/bin/sh

# A hook script to verify what is about to be committed.  Called by "git commit"
# with no arguments.  The hook should exit with non-zero status after issuing
# an appropriate message if it wants to stop the commit.
#
# The script lints and formats the code.

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${YELLOW}Running pre-commit lint...${NC}"

cd "$(dirname "$0")/.." || exit 1

# Run ruff check only (no format to avoid breaking code)
if command -v ruff >/dev/null 2>&1; then
    if ruff check py/ tests/ 2>&1; then
        echo -e "${GREEN}Ruff lint passed!${NC}"
    else
        echo -e "${RED}Ruff lint failed! Commit aborted.${NC}"
        exit 1
    fi
else
    echo -e "${YELLOW}ruff not found, skipping lint.${NC}"
fi

echo -e "${GREEN}Pre-commit lint passed!${NC}"
exit 0
